# AutoClaw publish credentials — copy to .env and fill in. NEVER commit .env.

# VS Code Marketplace personal access token
# Get one from https://dev.azure.com/<your-org>/_usersSettings/tokens (scope: Marketplace > Manage)
VSCE_PAT=

# Open VSX personal access token
# Get one from https://open-vsx.org/user-settings/tokens
# Used by `npm run publish:ovsx` (must own or co-publish to the ZippyTechnologiesLLC namespace)
OVSX_TOKEN=
