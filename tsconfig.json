{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "out",
    "lib": ["ES2020", "dom"],
    "types": ["node", "mocha"],
    "sourceMap": true,
    "rootDir": "src",
    "strict": true,
    "downlevelIteration": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", ".vscode-test", "scripts", "out", "adapters"]
}
