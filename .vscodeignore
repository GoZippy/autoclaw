# Secrets - never ship credentials
.env
.env.local
.env.*.local

# Dev source, tests, docs, scripts - ship compiled out/ only (minus tests/maps)
src/
test/
tests/
docs/
scripts/
packages/
*.vsix
tsconfig.tsbuildinfo

# Compiled test and script artifacts
out/test/
out/scripts/

# Source maps
*.js.map

# Dev tooling
.vscode/
.vscode-test/
.yarn/

# Runtime workspace data - not for distribution
.autoclaw/
.kilocodemodes
.kilo/
.voidspec/
.claude/
.clinerules/

# CI/CD internals
.github/
node_modules/.package-lock.json

# OS junk
.DS_Store
Thumbs.db

# Root dotfiles not needed by extension consumers
.gitignore
.gitattributes
.npmrc
.husky/
lint-staged*
.prettier*
.eslint*
.editorconfig
.babelrc
.travis.yml
.circleci/
dangerfile*
rollup.config*
webpack.config*
jest.config*
babel.config*
commitlint*
