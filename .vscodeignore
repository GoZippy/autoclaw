# Secrets - never ship credentials
.env
.env.local
.env.*.local
.mcp.json

# Dev source, tests, docs, scripts - ship compiled out/ only
src/**
test/
tests/
scripts/**
packages/**
*.vsix
tsconfig.tsbuildinfo

# Compiled test and script artifacts
out/test/**
out/scripts/**

# Source maps and TS artifacts in out/
out/**/*.map
out/**/*.ts

# Dev tooling
.vscode/
.vscode-test/
.yarn/

# Runtime workspace data - not for distribution
.autoclaw/
.claude/**
.clinerules/**
.kilo/**
.kilocodemodes
.voidspec/**
.cursor/**
.cursorignore

# CI/CD internals
.github/**
node_modules/.package-lock.json

# Intelligence Layer native peers — declared as optionalDependencies but NOT
# bundled. They follow the packages/kg-daemon native-peer model: maintainer-/
# user-installed locally, lazy-required only when a vector backend is used. The
# always-available `none` embedding provider needs none of them, so excluding
# them keeps the .vsix lean and packaging reliable.
node_modules/better-sqlite3/**
node_modules/sqlite-vec/**
node_modules/@xenova/**
node_modules/pg/**
node_modules/pg-*/**
node_modules/onnxruntime-node/**
node_modules/onnxruntime-common/**
node_modules/onnxruntime-web/**
node_modules/@huggingface/**
# Transitive deps of @xenova/transformers (the embeddings engine) — lazy-loaded
# alongside it and never touched by the core extension. The top-level optional
# dirs above are not enough: these hoist to node_modules root and would otherwise
# bloat the .vsix by ~135 MB (onnxruntime-web 66M + sharp 50M + protobufjs 19M).
node_modules/sharp/**
node_modules/protobufjs/**

# Session/working scratch — logs and ad-hoc output files, never for distribution
*.log
*_out.txt
intel-out.log
intel-err.log
.agents/**
semantic-review/**
research/**
reviews/**
test-run.log
*-test.log
*-test2.log

# OS junk
.DS_Store
Thumbs.db

# Root dotfiles not needed by extension consumers
.gitignore
.gitattributes
.npmrc
.husky/
lint-staged*
.prettier*
.eslint*
.editorconfig
.babelrc
.travis.yml
.circleci/
dangerfile*
rollup.config*
webpack.config*
jest.config*
babel.config*
commitlint*

# Local scratch / research
tmp/**

