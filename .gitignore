.mcp.json
node_modules/
out/
*.vsix
.vscode-test/
tsconfig.tsbuildinfo

# Local secrets — NEVER commit. Use .env.example as the template.
.env
.env.local
.env.*.local

# Private keys / certs — NEVER commit (only the public verify key lives in src/).
*.pem
*.key
*.p12
*.pfx
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*

# Private / paid code lives in the PRIVATE repo (@autoclaw/premium); never
# co-commit it into this public repo. (Guarded by scripts/check-no-secrets.js.)
premium-impl/
src/premium-private/
packages/premium/
packages/autoclaw-premium/

# Workspace files generated at runtime by the extension itself
.kilocodemodes

# AutoClaw KDream data
.autoclaw/

# Agent task-coordination runtime (mailbox, task/context state, review artifacts)
.agents/
# Intelligence Layer generated runtime data (covered by .autoclaw/ above; listed
# explicitly per the intelligence-foundation contract so it's never committed):
#   .autoclaw/vector/db.sqlite   — sqlite-vec store
#   .autoclaw/.locks/            — advisory file locks
#   .autoclaw/history/           — per-source extraction watermarks

# IDE workspace state — runtime data, not product code
.voidspec/
.kilo/
.claude/
.clinerules/

# Local research / scratch — referenced from specs but not in the repo
tmp/

# Scratch command-output dumps (transient; never commit)
*_out.txt
